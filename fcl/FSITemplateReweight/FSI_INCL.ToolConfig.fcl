FSI_INCL_Tool_Config: {

    tool_type: "FSIReweight"
    instance_name: "SBNNuSyst_FSI_INCLReweight_multisigma"

    FSIReweight_central_value: 0
    FSIReweight_variation_descriptor: "[0, 1]"

    FSIReweight_input_manifest: {
      input_file: "${NUSYST_FSI_TEMPLATE_DIR}/FSI_Evis_reweight_template.root"
      inputs: [
        {
          input_hist: "hA2018_protonPlus_KEini_vs_Ebias"
          name: "hist_nom_protonPlus"
        },
        {
          input_hist: "INCL++_protonPlus_KEini_vs_Ebias"
          name: "hist_alt_protonPlus"
        },
        {
          input_hist: "hA2018_neutron_KEini_vs_Ebias"
          name: "hist_nom_neutron"
        },
        {
          input_hist: "INCL++_neutron_KEini_vs_Ebias"
          name: "hist_alt_neutron"
        },
        {
          input_hist: "hA2018_piPlus_KEini_vs_Ebias"
          name: "hist_nom_piPlus"
        },
        {
          input_hist: "INCL++_piPlus_KEini_vs_Ebias"
          name: "hist_alt_piPlus"
        },
        {
          input_hist: "hA2018_pi0_KEini_vs_Ebias"
          name: "hist_nom_pi0"
        },
        {
          input_hist: "INCL++_pi0_KEini_vs_Ebias"
          name: "hist_alt_pi0"
        },
        {
          input_hist: "hA2018_piMinus_KEini_vs_Ebias"
          name: "hist_nom_piMinus"
        },
        {
          input_hist: "INCL++_piMinus_KEini_vs_Ebias"
          name: "hist_alt_piMinus"
        }
      ]
    }

  }

syst_providers: [FSI_INCL_Tool_Config]
